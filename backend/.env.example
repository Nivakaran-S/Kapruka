# Copy to .env for local dev (never commit .env). On Hugging Face / Vercel, set these
# as project secrets/variables instead.

# Required — your Groq API key (https://console.groq.com/keys)
GROQ_API_KEY=gsk_your_key_here

# Optional overrides
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_MAX_TOKENS=1024
GROQ_REASONING_EFFORT=low          # only applies to gpt-oss-* models
AGENT_RECURSION_LIMIT=12
KAPRUKA_MCP_URL=https://mcp.kapruka.com/mcp

# Comma-separated extra allowed origins for CORS (any *.vercel.app is already allowed)
ALLOWED_ORIGINS=http://localhost:3000
