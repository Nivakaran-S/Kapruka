# Copy to .env for local dev (never commit .env). On Hugging Face, set these as
# Space secrets/variables instead.

# Required — your Groq API key (https://console.groq.com/keys)
GROQ_API_KEY=gsk_your_key_here

# Optional overrides
GROQ_MODEL=openai/gpt-oss-120b
GROQ_REASONING_EFFORT=medium
KAPRUKA_MCP_URL=https://mcp.kapruka.com/mcp

# Comma-separated extra allowed origins for CORS (any *.vercel.app is already allowed)
ALLOWED_ORIGINS=http://localhost:3000
